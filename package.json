{
  "name": "modern-pdf-lib",
  "version": "0.39.0",
  "description": "A modern, WASM-accelerated PDF engine to create, parse, extract, fill, merge, and sign PDFs in every JavaScript runtime",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "import": "./dist/browser.mjs"
    },
    "./create": {
      "types": "./dist/create.d.mts",
      "import": "./dist/create.mjs",
      "require": {
        "types": "./dist/create.d.cts",
        "default": "./dist/create.cjs"
      }
    },
    "./parse": {
      "types": "./dist/parse.d.mts",
      "import": "./dist/parse.mjs",
      "require": {
        "types": "./dist/parse.d.cts",
        "default": "./dist/parse.cjs"
      }
    },
    "./forms": {
      "types": "./dist/forms.d.mts",
      "import": "./dist/forms.mjs",
      "require": {
        "types": "./dist/forms.d.cts",
        "default": "./dist/forms.cjs"
      }
    },
    "./wasm/*": "./dist/wasm/*"
  },
  "bin": {
    "modern-pdf": "./dist/cli/index.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "unpkg": "./dist/browser.mjs",
  "jsdelivr": "./dist/browser.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**/*.mjs",
    "dist/**/*.cjs",
    "dist/**/*.d.mts",
    "dist/**/*.d.cts",
    "dist/**/*.d.mts.map",
    "dist/**/*.d.cts.map",
    "dist/modern-pdf-lib.iife.js",
    "dist/wasm/**",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=26.4"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown && node scripts/finalize-dts.mjs && node scripts/smoke-dist.mjs",
    "smoke": "node scripts/smoke-dist.mjs",
    "build:iife": "tsx scripts/build-iife.ts",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:all": "npm run build:wasm && npm run build && npm run build:iife && npm run copy:wasm",
    "copy:wasm": "bash -c 'mkdir -p dist/wasm && for d in src/wasm/*/pkg; do crate=$(basename $(dirname $d)); mkdir -p dist/wasm/$crate && cp $d/*.wasm $d/*.js $d/*.d.ts dist/wasm/$crate/ 2>/dev/null || true; done'",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:bench": "vitest bench",
    "bench": "tsx tests/benchmarks/run.ts",
    "lint": "oxlint --type-aware src tests",
    "lint:fix": "oxlint --type-aware --fix src tests",
    "format": "prettier --write \"{src,tests,scripts}/**/*.ts\"",
    "format:check": "prettier --check \"{src,tests,scripts}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:api": "node tools/docs/node_modules/typedoc/bin/typedoc && tsx scripts/sanitize-api-docs.ts",
    "validate-pdf": "tsx scripts/validate-pdf.ts",
    "generate:wasm-inline": "tsx scripts/generate-inline-wasm.ts",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "fflate": "0.8.3"
  },
  "devDependencies": {
    "@playwright/test": "1.62.0-alpha-2026-06-25",
    "@vitest/coverage-v8": "5.0.0-beta.5",
    "esbuild": "0.28.1",
    "fast-png": "8.0.0",
    "miniflare": "4.20260625.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "pdf-lib": "^1.17.1",
    "prettier": "4.0.0-alpha.13",
    "rollup": "4.62.2",
    "tsdown": "0.22.3",
    "tsx": "4.22.4",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "7.0.1-rc",
    "vite": "8.1.0",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "5.0.0-beta.5",
    "wasm-pack": "0.15.0"
  },
  "keywords": [
    "pdf",
    "pdf-generation",
    "pdf-parser",
    "pdf-extraction",
    "text-extraction",
    "pdf-forms",
    "pdf-signature",
    "wasm",
    "typescript",
    "esm",
    "cloudflare-workers",
    "streaming"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ABCrimson/modern-pdf-lib.git"
  },
  "homepage": "https://github.com/ABCrimson/modern-pdf-lib#readme",
  "bugs": {
    "url": "https://github.com/ABCrimson/modern-pdf-lib/issues"
  }
}
